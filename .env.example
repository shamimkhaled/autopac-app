# ---------------------------
# DATABASE CONFIGURATION
# ---------------------------
# Replace with your MySQL connection string.
# Example for MySQL: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/autopac_db"

# ---------------------------
# NEXT AUTH CONFIGURATION
# ---------------------------
# IMPORTANT: Generate a strong secret with: openssl rand -base64 32
# NEVER use a simple/guessable string in production.
NEXTAUTH_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_32"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------
# APP CONFIGURATION
# ---------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------------------------
# SMTP / EMAIL CONFIGURATION
# ---------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your_app_password"
SMTP_FROM="support@autopacbd.com"
ADMIN_EMAIL="autopacbd@gmail.com"

# ---------------------------
# ANALYTICS (Optional)
# ---------------------------
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=""
# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=""

# ---------------------------
# GOOGLE ADSENSE (Optional)
# ---------------------------
# Your AdSense publisher ID (e.g. ca-pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=""

# ---------------------------
# GOOGLE SEARCH CONSOLE (Optional)
# ---------------------------
# Your Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
